# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_USER_TOKEN=xoxp-...        # 스레드 읽기, 이미지 다운로드, DM 전송
MY_SLACK_USER_ID=U...            # 초안을 받을 본인 유저 ID

# MCP 서버 (Bring Your Own)
# 필요한 MCP 서버를 아래 형식으로 추가
# 키 이름은 MCP_SERVER_로 시작, 값은 URL
# agent.py가 MCP_SERVER_ 접두사 환경변수를 자동으로 감지해서 mcp_servers에 추가
#
# 예시:
# MCP_SERVER_SLACK=https://your-slack-mcp-server/sse
# MCP_SERVER_GITHUB=https://your-github-mcp-server/sse
# MCP_SERVER_FOO=https://your-custom-mcp-server/sse
